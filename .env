# Database Configuration
DB_USER=messaging_user
DB_PASSWORD=messaging_pass
DB_HOST=localhost
DB_PORT=5432
DB_NAME=messaging_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Connection Pool
DB_POOL_MIN_SIZE=10
DB_POOL_MAX_SIZE=20

# Listener
LISTENER_ENABLED=true
LISTENER_POLL_INTERVAL_SECONDS=2
LISTENER_HTTP_TIMEOUT_SECONDS=10
LISTENER_RETRY_DELAY_SECONDS=30