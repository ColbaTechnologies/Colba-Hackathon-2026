{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PollJobConfig": {
    "Schedule": "* * * * * ?"
  },
  "RetryJobConfig": {
    "Schedule": "0/10 * * * * ?"
  }
}
